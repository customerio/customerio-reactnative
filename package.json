{
  "name": "customerio-reactnative",
  "version": "4.2.4",
  "description": "Official Customer.io SDK using React Native. Track customers and send messages to your iOS/Android apps.",
  "source": "./src/index.ts",
  "main": "./lib/module/index.js",
  "exports": {
    ".": {
      "types": "./lib/typescript/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "module": "./lib/module/index.js",
  "cioNativeiOSSdkVersion": "= 3.8.1",
  "iosSwiftVersion": "5.0",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "pre-deploy": "npm run typescript",
    "test": "jest",
    "typecheck": "tsc",
    "typescript": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "clean": "del-cli android/build example/android/build example/android/app/build example/ios/build lib example/ios/Pods example/ios/Podfile.lock example/node_modules node_modules",
    "lint:report": "npm run lint -- --output-file eslint_report.json --format json",
    "prepare": "bob build",
    "postinstall": "node src/postInstall.js",
    "format": "npx prettier --write \"src/**/*.tsx\" && (npm run lint || true)"
  },
  "keywords": [
    "react-native",
    "ios",
    "android"
  ],
  "repository": "https://github.com/customerio/customerio-reactnative",
  "author": "Customer.io Mobile Development Team (https://customer.io/)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/customerio/customerio-reactnative/issues"
  },
  "homepage": "https://github.com/customerio/customerio-reactnative#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@evilmartians/lefthook": "^1.5.0",
    "@react-native-community/cli": "18.0.0",
    "@react-native-community/cli-platform-android": "18.0.0",
    "@react-native-community/cli-platform-ios": "18.0.0",
    "@react-native/babel-preset": "0.79.1",
    "@react-native/eslint-config": "0.79.1",
    "@react-native/metro-config": "0.79.1",
    "@types/jest": "^29.5.5",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "commitlint": "^19.6.1",
    "del-cli": "^5.1.0",
    "eslint": ">=6.0.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.6",
    "jest": "^29.7.0",
    "lefthook": "^1.11.10",
    "prettier": "^3.5.3",
    "react": "19.0.0",
    "react-native": ">=0.79.0",
    "react-native-builder-bob": "^0.40.6",
    "turbo": "^1.10.7",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "@react-native/eslint-config",
      "prettier"
    ],
    "plugins": [
      "prettier"
    ],
    "rules": {
      "prettier/prettier": [
        "error",
        {
          "quoteProps": "consistent",
          "singleQuote": true,
          "tabWidth": 2,
          "trailingComma": "es5",
          "useTabs": false
        }
      ]
    }
  },
  "eslintIgnore": [
    "node_modules/",
    "Apps/",
    "example/",
    "lib/"
  ],
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module"
      ],
      [
        "commonjs"
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}