    "expo-status-bar": "~1.12.1",
    "expo-updates": "~0.25.27",
    "react": "18.3.1",
    "react-native": "^0.76.1",
    "react-native-device-info": "^14.0.0",
    "react-native-gesture-handler": "^2.20.2",
